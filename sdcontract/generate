#!/usr/bin/env python
import json
import subprocess
import sys
from pathlib import Path


def _run(cmd, cwd, label):
    proc = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    if proc.stdout:
        sys.stderr.write(proc.stdout)
    if proc.stderr:
        sys.stderr.write(proc.stderr)
    if proc.returncode != 0:
        tail = (proc.stderr or proc.stdout or "").strip()[-1500:]
        raise RuntimeError(f"{label} exited {proc.returncode}: {tail}")


def main():
    req = json.load(sys.stdin)
    real_stdout = sys.stdout
    sys.stdout = sys.stderr
    try:
        model_dir = req["model_dir"]
        out_csv = req["output_csv_path"]
        n_samples = req["n_samples"]
        device = req.get("device", "cpu")

        meta_path = Path(model_dir) / "train_meta.json"
        if meta_path.exists():
            with open(meta_path) as f:
                meta = json.load(f)
            train_csv = meta.get("train_csv")
            label_col = meta.get("label_col")
        else:
            raise RuntimeError("train_meta.json not found in model_dir")

        raw_constraints = req.get("constraints", [])

        sys.path.insert(0, str(Path(__file__).resolve().parents[3]))
        from sdcontract_core.constraints import parse, to_spec

        relddpm_dir = Path(__file__).resolve().parent.parent

        if len(raw_constraints) == 0:
            cmd = [
                "python", "main.py",
                "--task-name=sample_unconditional",
                f"--train-csv={train_csv}",
                f"--save-name={model_dir}",
                f"--n-samples={n_samples}",
                f"--output-csv={out_csv}",
                f"--device={device}",
            ]
            if label_col:
                cmd.append(f"--label-col={label_col}")
            _run(cmd, relddpm_dir, "sample_unconditional")
        else:
            if len(raw_constraints) != 1:
                raise ValueError("Original RelDDPM requires exactly one equality constraint or zero constraints (unconditional).")
            if not label_col:
                raise ValueError("The trained artifact does not define a label column.")

            constraint = parse(raw_constraints[0])
            to_spec(constraint, "equality")
            if constraint.column != label_col:
                raise ValueError(
                    f"Constraint column '{constraint.column}' does not match trained "
                    f"label column '{label_col}'."
                )
            target_class = constraint.value

            cmd = [
                "python", "main.py",
                "--task-name=sample",
                f"--train-csv={train_csv}",
                f"--save-name={model_dir}",
                f"--n-samples={n_samples}",
                f"--output-csv={out_csv}",
                f"--device={device}",
            ]
            if label_col:
                cmd.append(f"--label-col={label_col}")
            cmd.append(f"--target-class={target_class}")

            _run(cmd, relddpm_dir, "sample")

        result = {"ok": True, "output_csv": out_csv, "message": ""}
    except Exception as e:
        result = {"ok": False, "output_csv": None, "message": f"{type(e).__name__}: {e}"}
    finally:
        sys.stdout = real_stdout
    print(json.dumps(result))

if __name__ == "__main__":
    sys.exit(main() or 0)
